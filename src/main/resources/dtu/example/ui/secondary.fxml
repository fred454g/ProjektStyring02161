<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1100.0"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dtu.example.ui.SecondaryController">

    <children>

        <HBox alignment="CENTER_LEFT" prefHeight="60.0"
              style="-fx-background-color: #f8f8f8; -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="Softwarehuset A/S - Projektstyring">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#handleLogout"
                        prefHeight="36.0"
                        prefWidth="120.0"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Log ud" />
            </children>
            <padding>
                <Insets left="24.0" right="24.0" />
            </padding>
        </HBox>

        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>

                <Tab text="Projekter">
                    <content>
                        <ScrollPane fitToWidth="true">
                            <content>
                                <VBox spacing="20.0">
                                    <padding>
                                        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                                    </padding>

                                    <children>
                                        <Label text="Projekter">
                                            <font>
                                                <Font name="System Bold" size="20.0" />
                                            </font>
                                        </Label>

                                        <FlowPane hgap="24.0" vgap="24.0">

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Opret projekt">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <TextField fx:id="nytProjektNavnInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projektnavn" />
                                                    <Button onAction="#handleOpretProjekt" prefHeight="38.0" maxWidth="Infinity" text="Opret projekt"
                                                            style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Omdøb projekt">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForOmdobInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <TextField fx:id="nytProjektNavnOmdobInput" prefHeight="36.0" maxWidth="Infinity" promptText="Nyt projektnavn" />
                                                    <Button onAction="#handleOmdobProjekt" prefHeight="38.0" maxWidth="Infinity" text="Omdøb projekt"
                                                            style="-fx-background-color: #f39c12; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Tilknyt projektleder">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForLederInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="projektlederInitialerVaelger" prefHeight="36.0" maxWidth="Infinity" promptText="Projektleder" />
                                                    <Button onAction="#handleTilknytProjektleder" prefHeight="38.0" maxWidth="Infinity" text="Tilknyt projektleder"
                                                            style="-fx-background-color: #34495e; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Tilknyt medarbejder til projekt">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForProjektMedarbejderInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="medarbejderTilProjektVaelger" prefHeight="36.0" maxWidth="Infinity" promptText="Medarbejder" />
                                                    <Button onAction="#handleTilknytMedarbejderTilProjekt" prefHeight="38.0" maxWidth="Infinity" text="Tilknyt medarbejder"
                                                            style="-fx-background-color: #34495e; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Fjern medarbejder fra projekt">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForFjernProjektMedarbejderInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="medarbejderFraProjektVaelger" prefHeight="36.0" maxWidth="Infinity" promptText="Medarbejder" />
                                                    <Button onAction="#handleFjernMedarbejderFraProjekt" prefHeight="38.0" maxWidth="Infinity" text="Fjern medarbejder"
                                                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                        </FlowPane>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <Tab text="Aktiviteter">
                    <content>
                        <ScrollPane fitToWidth="true">
                            <content>
                                <VBox spacing="20.0">
                                    <padding>
                                        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                                    </padding>

                                    <children>
                                        <Label text="Aktiviteter">
                                            <font>
                                                <Font name="System Bold" size="20.0" />
                                            </font>
                                        </Label>

                                        <FlowPane hgap="24.0" vgap="24.0">

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Opret aktivitet">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForAktivitetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <TextField fx:id="aktivitetsNavnInput" prefHeight="36.0" maxWidth="Infinity" promptText="Navn" />
                                                    <TextField fx:id="budgetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Budget i timer" />
                                                    <TextField fx:id="startUgeAktivitetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Start uge" />
                                                    <TextField fx:id="slutUgeAktivitetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Slut uge" />
                                                    <Button onAction="#handleOpretAktivitet" prefHeight="38.0" maxWidth="Infinity" text="Opret aktivitet"
                                                            style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Find ledige medarbejdere">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <Label text="Viser medarbejdere uden fravær og uden overlappende aktivitet." wrapText="true" textFill="#666666" />
                                                    <TextField fx:id="ledigStartUgeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Start uge" />
                                                    <TextField fx:id="ledigSlutUgeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Slut uge" />
                                                    <Button onAction="#handleVisLedige" prefHeight="38.0" maxWidth="Infinity" text="Find ledige"
                                                            style="-fx-background-color: #16a085; -fx-text-fill: white;" />
                                                    <TextArea fx:id="ledigeOutput" editable="false" prefHeight="120.0" maxWidth="Infinity"
                                                              style="-fx-font-family: monospace;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Opdater aktivitet">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForOpdaterAktivitetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="aktivitetForOpdateringInput" prefHeight="36.0" maxWidth="Infinity" promptText="Aktivitet" />
                                                    <TextField fx:id="nytBudgetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Nyt budget" />
                                                    <TextField fx:id="nyStartUgeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Ny start uge" />
                                                    <TextField fx:id="nySlutUgeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Ny slut uge" />
                                                    <Button onAction="#handleOpdaterAktivitet" prefHeight="38.0" maxWidth="Infinity" text="Opdater aktivitet"
                                                            style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Slet aktivitet">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForSletAktivitetInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="aktivitetForSletningInput" prefHeight="36.0" maxWidth="Infinity" promptText="Aktivitet" />
                                                    <Button onAction="#handleSletAktivitet" prefHeight="38.0" maxWidth="Infinity" text="Slet aktivitet"
                                                            style="-fx-background-color: #c0392b; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Tilknyt medarbejder til aktivitet">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForTilknytningInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="aktivitetForTilknytningInput" prefHeight="36.0" maxWidth="Infinity" promptText="Aktivitet" />
                                                    <ComboBox fx:id="medarbejderInitialerVaelger" prefHeight="36.0" maxWidth="Infinity" promptText="Medarbejder" />
                                                    <Button onAction="#handleTilknytMedarbejder" prefHeight="38.0" maxWidth="Infinity" text="Tilknyt medarbejder"
                                                            style="-fx-background-color: #34495e; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                            <VBox prefWidth="320.0" spacing="12.0"
                                                  style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                                <children>
                                                    <Label text="Fjern medarbejder fra aktivitet">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ComboBox fx:id="projektIdForFjernMedarbejderInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                                    <ComboBox fx:id="aktivitetForFjernMedarbejderInput" prefHeight="36.0" maxWidth="Infinity" promptText="Aktivitet" />
                                                    <ComboBox fx:id="medarbejderForFjernelseVaelger" prefHeight="36.0" maxWidth="Infinity" promptText="Medarbejder" />
                                                    <Button onAction="#handleFjernMedarbejderFraAktivitet" prefHeight="38.0" maxWidth="Infinity" text="Fjern medarbejder"
                                                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" />
                                                </children>
                                            </VBox>

                                        </FlowPane>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <Tab text="Tidsregistrering">
                    <content>
                        <VBox alignment="CENTER" spacing="15.0">
                            <padding>
                                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                            </padding>

                            <children>
                                <Label text="Registrer tid">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>

                                <VBox prefWidth="420.0" spacing="12.0"
                                      style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                    <children>
                                        <ComboBox fx:id="projektIdTidInput" prefHeight="36.0" maxWidth="Infinity" promptText="Projekt" />
                                        <ComboBox fx:id="aktivitetsNavnTidInput" prefHeight="36.0" maxWidth="Infinity" promptText="Aktivitet" />
                                        <TextField fx:id="timerInput" prefHeight="36.0" maxWidth="Infinity" promptText="Timer" />

                                        <Button onAction="#handleRegistrerTid" prefHeight="38.0" maxWidth="Infinity" text="Gem tidsregistrering"
                                                style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />

                                        <Separator />

                                        <Button onAction="#handleVisEgneTimer" prefHeight="38.0" maxWidth="Infinity" text="Vis egne timer"
                                                style="-fx-background-color: #34495e; -fx-text-fill: white;" />

                                        <TextArea fx:id="egneTimerOutput" editable="false" prefHeight="80.0" maxWidth="Infinity"
                                                  style="-fx-font-family: monospace;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Fravær">
                    <content>
                        <VBox alignment="CENTER" spacing="15.0">
                            <padding>
                                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                            </padding>

                            <children>
                                <Label text="Registrer fravær">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>

                                <VBox prefWidth="420.0" spacing="12.0"
                                      style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;">
                                    <children>
                                        <TextField fx:id="fravaerTypeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Type" />
                                        <TextField fx:id="startUgeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Start uge" />
                                        <TextField fx:id="slutUgeInput" prefHeight="36.0" maxWidth="Infinity" promptText="Slut uge" />

                                        <Button onAction="#handleRegistrerFravaer" prefHeight="38.0" maxWidth="Infinity" text="Gem fravær"
                                                style="-fx-background-color: #e67e22; -fx-text-fill: white;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Statusrapport">
                    <content>
                        <VBox spacing="15.0">
                            <padding>
                                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                            </padding>

                            <children>
                                <Label text="Statusrapport">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>

                                <HBox spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="rapportProjektIdInput" prefHeight="36.0" prefWidth="260.0" promptText="Projekt" />
                                        <Button onAction="#handleGenererRapport" prefHeight="36.0" prefWidth="160.0" text="Generer"
                                                style="-fx-background-color: #9b59b6; -fx-text-fill: white;" />
                                    </children>
                                </HBox>

                                <TextArea fx:id="rapportOutput" prefHeight="360.0" maxWidth="Infinity"
                                          style="-fx-font-family: monospace;" />
                            </children>
                        </VBox>
                    </content>
                </Tab>

            </tabs>
        </TabPane>

    </children>
</VBox>